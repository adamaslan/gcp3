# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# API Keys (never commit real values)
FINNHUB_API_KEY=your-finnhub-api-key

# Frontend → Backend (Cloud Run backend URL)
# Vercel: set in dashboard Settings → Environment Variables → BACKEND_URL
#         also configure as @backend_url secret in Vercel project settings
# Local:  copy this file to .env.local and fill in the real URL
BACKEND_URL=https://gcp3-backend-xxx-uc.a.run.app

# Frontend deployment domain (needed for OG image URL resolution)
# Vercel: set in dashboard Settings → Environment Variables
# Default: https://nuwrrrld.com (main domain)
# Subdomains: set to deployment domain (e.g., https://sectors.nuwrrrld.com)
NEXT_PUBLIC_SITE_URL=https://nuwrrrld.com

# Only needed when deploying frontend to Cloud Run (not Vercel)
NEXT_PUBLIC_APP_URL=https://gcp3-frontend-xxx-uc.a.run.app
