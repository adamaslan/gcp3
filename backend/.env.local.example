# Local dev config for running the GCP3 Finance API without any GCP access.
# Copy to .env (or export) and run ./run_local.sh.

# --- Cache backend: run without Firestore/GCP ---
CACHE_BACKEND=sqlite
LOCAL_CACHE_DB=./local_cache.db

# NOTE: do NOT set GCP_PROJECT_ID for a pure-local run. If it's set, the sqlite
# backend still wins (CACHE_BACKEND takes precedence), but leaving it unset makes
# the intent clear and proves no Firestore path is reached.

# --- Server ---
PORT=8080
RELOAD=1

# --- Market data (read from environment or backend/.env) ---
# Required for live quotes; endpoints degrade gracefully when a source is missing.
FINNHUB_API_KEY=
# Optional fallbacks:
# ALPHAVANTAGE_API_KEY=
# OPENROUTER_API_KEY=
